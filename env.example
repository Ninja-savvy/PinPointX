# EMBA configuration
EMBA_PATH=/opt/emba
EMBA_LOG_DIR=/home/user/projects/myapp/emba_logs
EMBA_DIFF_LOG_DIR=/home/user/projects/myapp/emba_diff_logs
EMBA_FIRMWARE_DIR=/home/user/projects/myapp/uploads/firmware
EMBA_USE_SUDO=0
EMBA_TIMEOUT_SEC=86400
EMBA_DIFF_TIMEOUT_SEC=86400
EMBA_DIFF_MODE=2
EMBA_JOB_TIMEOUT_SEC=86400
EMBA_STREAM_TIMEOUT_SEC=86400

# Vision providers
OLLAMA_HOST=http://<your_ip>:11434
OLLAMA_MODEL=your-vision-model:latest
OLLAMA_TEXT_MODEL=your-text-model:latest
OLLAMA_CHAT_MODEL=your-chat-model:latest
OLLAMA_TEXT_API_BASE=http://host.docker.internal:11434
OLLAMA_TIMEOUT_SEC=300
OLLAMA_TEXT_TIMEOUT_SEC=300
TOOL_VISION_TIMEOUT_SEC=120
TOOL_VISUAL_CONFIRMED=0.75
TOOL_VISUAL_LIKELY=0.50
TOOL_VISUAL_MIN_SCORE=0.35
PCB_USE_VLM_HINTS=1

# HuggingFace fallback
# Leave HUGGINGFACE_API_KEY empty to disable
HUGGINGFACE_API_URL=https://router.huggingface.co/v1/chat/completions
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# PCB pipeline thresholds
PCB_PREFILTER_REJECT_THRESHOLD=0.40
PCB_PREFILTER_PASS_THRESHOLD=0.70
PCB_OCR_FALLBACK_THRESHOLD=0.60
PCB_ENABLE_TEXT_VALIDATION=1
PCB_TEXT_VALIDATION_MAX_ITEMS=32
PCB_MIN_VOTES_TO_FLAG=1
PCB_MIN_VOTES_HIGH_CONF=2
PCB_CLIP_MODEL_ID=openai/clip-vit-base-patch32
PCB_OCR_LANGS=en
